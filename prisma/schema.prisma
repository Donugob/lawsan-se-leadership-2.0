generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Delegate {
  id            String   @id @default(cuid())
  regId         String?  @unique // LLC-XXXXX
  firstName     String
  lastName      String
  email         String   @unique
  phone         String
  
  isStudent     Boolean
  isLawStudent  Boolean?
  isSouthEast   Boolean?
  
  // Student fields
  university    String?
  level         String?
  
  // Professional fields
  profession    String?
  organization  String?
  
  // Payment info
  amount        Int      @default(3150)
  status        String   @default("pending") // pending, paid, failed
  paystackRef   String?  @unique
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Transaction {
  id            String   @id @default(cuid())
  reference     String   @unique
  email         String
  amount        Int
  status        String   // success, abandoned, failed, reversed
  channel       String?
  currency      String?
  ipAddress     String?
  paidAt        DateTime?
  metadata      Json?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed
  name      String
  role      String   @default("ADMIN") // SUPER_ADMIN, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  auditLogs AuditLog[]
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  adminName String
  action    String
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  admin     Admin?   @relation(fields: [adminId], references: [id])
}

model AdminInvitation {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("ADMIN")
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
